{
  "name": "sick",
  "version": "1.2.1",
  "license": "MIT",
  "scripts": {
    "ng": "nx",
    "start": "nx serve",
    "start:fe": "nx serve web",
    "start:be": "nx serve api",
    "build": "nx build",
    "build:all": "nx run-many --target=build --projects=api,web --parallel --prod --skip-nx-cache",
    "test": "nx test",
    "lint-staged": "lint-staged --allow-empty",
    "docker:dev": "docker compose -f docker-compose.dev.yml up -d --build --remove-orphans",
    "docker:prod": "docker compose build --pull && docker compose up -d --force-recreate --remove-orphans",
    "prepare": "husky install",
    "format:check": "prettier apps/**/*.{ts,html,scss,json} libs/**/*.{ts,html,scss,json} --check",
    "format:fix": "prettier apps/**/*.{ts,html,scss,json} libs/**/*.{ts,html,scss,json} --write",
    "pretty-quick": "pretty-quick --pattern \"**/*.*(js|ts|css|scss|html)\" --staged"
  },
  "husky": {
    "hooks": "pnpm run format:fix && npx validate-branch-name && npx lint-staged"
  },
  "validate-branch-name": {
    "pattern": "^(main|develop){1}$|^(feature|bugfix|hotfix|release)-.+$/g",
    "errorMsg": "Branch name has to be main or develop or has to start with feature-, bugfix-, hotfix- or release-"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ],
    "rules": {
      "body-max-line-length": [
        1,
        "always",
        100
      ]
    }
  },
  "lint-staged": {
    "*.{ts,js,html,css,scss,less,md,json}": "prettier --write --ignore-unknown"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "~21.1.6",
    "@angular/cdk": "~21.1.6",
    "@angular/common": "~21.1.6",
    "@angular/compiler": "~21.1.6",
    "@angular/core": "~21.1.6",
    "@angular/forms": "~21.1.6",
    "@angular/material": "~21.1.6",
    "@angular/platform-browser": "~21.1.6",
    "@angular/platform-browser-dynamic": "~21.1.6",
    "@angular/router": "~21.1.6",
    "@aws-sdk/client-s3": "^3.1023.0",
    "@aws-sdk/lib-storage": "^3.1023.0",
    "@nestjs/common": "^11.1.18",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.18",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mongoose": "^11.0.4",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.18",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/throttler": "^6.5.0",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "cookie-parser": "^1.4.7",
    "mongoose": "^8.23.0",
    "multer": "^2.1.1",
    "passport": "^0.6.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "sharp": "^0.34.5",
    "swagger-ui-express": "^5.0.1",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "~21.1.5",
    "@angular-devkit/core": "~21.1.5",
    "@angular-devkit/schematics": "~21.1.5",
    "@angular-eslint/eslint-plugin": "21.3.1",
    "@angular-eslint/eslint-plugin-template": "21.3.1",
    "@angular-eslint/template-parser": "21.3.1",
    "@angular/build": "~21.1.5",
    "@angular/cli": "~21.1.5",
    "@angular/compiler-cli": "~21.1.6",
    "@angular/language-service": "~21.1.6",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@nestjs/schematics": "^11.0.10",
    "@nestjs/testing": "^11.1.18",
    "@nx/angular": "22.7.0-beta.10",
    "@nx/eslint": "22.7.0-beta.10",
    "@nx/eslint-plugin": "22.7.0-beta.10",
    "@nx/js": "22.7.0-beta.10",
    "@nx/nest": "22.7.0-beta.10",
    "@nx/node": "22.7.0-beta.10",
    "@nx/web": "22.7.0-beta.10",
    "@nx/webpack": "22.7.0-beta.10",
    "@nx/workspace": "22.7.0-beta.10",
    "@schematics/angular": "21.1.1",
    "@swc-node/register": "1.11.1",
    "@swc/core": "1.15.8",
    "@swc/helpers": "0.5.18",
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.2",
    "@types/passport-jwt": "^3.0.13",
    "@types/passport-local": "^1.0.38",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@typescript-eslint/utils": "^7.18.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jsdom": "^27.4.0",
    "lint-staged": "^13.3.0",
    "nx": "22.7.0-beta.10",
    "prettier": "^3.8.1",
    "pretty-quick": "^4.2.2",
    "ts-node": "^10.9.2",
    "tslint-config-prettier": "^1.18.0",
    "typescript": "~5.9.3",
    "validate-branch-name": "^1.3.2",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@parcel/watcher",
      "@scarf/scarf",
      "@swc/core",
      "bcrypt",
      "esbuild",
      "less",
      "lmdb",
      "msgpackr-extract",
      "nx",
      "oxc-resolver",
      "sharp",
      "unrs-resolver"
    ]
  }
}
