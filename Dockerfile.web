ARG NODE_VERSION=lts-alpine
ARG NGINX_VERSION=1.27-alpine

# ========================================
# Base Node.js stage
# ========================================
FROM node:${NODE_VERSION} AS node-base
WORKDIR /app

# Install pnpm globally
RUN npm install -g pnpm@latest

# ========================================
# Workspace dependencies
# ========================================
FROM node-base AS workspace-deps
WORKDIR /app

# Copy package files for dependency installation
COPY package.json pnpm-lock.yaml ./

# Install all dependencies once and reuse this layer for app builders
RUN pnpm install --frozen-lockfile

# ========================================
# Web build stage
# ========================================
FROM workspace-deps AS web-builder
WORKDIR /app

ARG WEB_BUILD_TARGET=web:build:production

# Copy the full frontend sources required for the Angular build
COPY apps/web ./apps/web
COPY libs/web ./libs/web
COPY libs/shared ./libs/shared
COPY tsconfig.base.json nx.json ./

# Build the frontend deployment artifact
RUN pnpm nx run ${WEB_BUILD_TARGET} --skip-nx-cache

# ========================================
# Web development image
# ========================================
FROM workspace-deps AS web-dev
WORKDIR /app

# Copy the workspace files needed for Angular watch mode inside the container.
COPY nx.json tsconfig.base.json ./
COPY apps/web ./apps/web
COPY libs/web ./libs/web
COPY libs/shared ./libs/shared

# ========================================
# Web production image
# ========================================
FROM nginx:${NGINX_VERSION} AS web

# Copy custom nginx config
COPY nginx.conf /etc/nginx/nginx.conf

# Copy built web application
COPY --from=web-builder /app/dist/apps/web/browser /usr/share/nginx/html

# Copy config file if it exists
COPY --chown=nginx:nginx .config.json* /usr/share/nginx/html/

# Create non-root nginx user and set permissions
RUN chown -R nginx:nginx /usr/share/nginx/html && \
    chown -R nginx:nginx /var/cache/nginx && \
    chown -R nginx:nginx /var/log/nginx && \
    touch /var/run/nginx.pid && \
    chown -R nginx:nginx /var/run/nginx.pid

# Switch to non-root user
USER nginx

# Expose ports
EXPOSE 8080

# Health check
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
    CMD wget --no-verbose --tries=1 --spider http://localhost:8080/ || exit 1

# Start nginx
CMD ["nginx", "-g", "daemon off;"]
