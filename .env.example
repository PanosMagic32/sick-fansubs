# Application Configuration
NODE_ENV=production
PORT=3333

# Docker Compose Ports
API_PORT=3333
WEB_HTTP_PORT=8080

# Database Configuration (Mongo Atlas)
DATABASE_URL=mongodb+srv://<atlas-user>:<atlas-pass>@<atlas-cluster>/<db-name>?retryWrites=true&w=majority

# Development (docker-compose.dev.yml)
DATABASE_URL_DEV=mongodb+srv://<atlas-user>:<atlas-pass>@<atlas-cluster>/<db-name>?retryWrites=true&w=majority

# API Configuration
API_URL=http://localhost:3333/api
JWT_SECRET=change_this_secret_key
JWT_EXPIRATION_TIME=900s
JWT_REFRESH_SECRET=change_this_refresh_secret_key
JWT_REFRESH_EXPIRATION_TIME=7d

# Add your other environment variables here
APP_VERSION=version-number-in-MAJOR.MINOR.PATCH-format

# MinIO Object Storage
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=change_this_minio_key
MINIO_SECRET_KEY=change_this_minio_secret
MINIO_BUCKET=images
MINIO_REGION=us-east-1
# Public base URL for media links returned by the API (no trailing slash)
MINIO_PUBLIC_BASE_URL=https://your-domain.com
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001