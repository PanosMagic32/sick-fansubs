{
  "name": "api-project",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/api/project/src",
  "projectType": "library",
  "tags": ["scope:api"],
  "// targets": "to see all targets run: nx show project api-project --web",
  "targets": {
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm vitest run --config vitest.config.ts --environment node libs/api/project/src"
      },
      "configurations": {},
      "parallelism": true
    }
  }
}
